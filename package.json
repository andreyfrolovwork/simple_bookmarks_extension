    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "svelte": "^5.42.2",
    "svelte-check": "^4.3.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "vite": "^7.1.12"
  },
  "dependencies": {
    "fuse.js": "^7.1.0",
    "pixelarticons": "^1.8.1"
